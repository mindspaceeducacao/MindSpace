<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Conquistas de Artes</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Montserrat', sans-serif; }
        body { background-color: #ffffff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding-bottom: 50px; }
        .bg-pattern { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background-image: linear-gradient(135deg, #4461f2 10%, #7a91f5 10%, #7a91f5 15%, #b2c0f9 15%, #b2c0f9 20%, transparent 20%); opacity: 0.5; }
        
        header { text-align: center; margin: 60px 0; }
        header h1 { font-size: 2.2rem; color: #333; }
        .main-icon { color: #f1c40f; font-size: 3.5rem; margin-bottom: 10px; }

        .container { background: white; width: 90%; max-width: 500px; padding: 35px; border-radius: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.1); text-align: center; }
        
        select { width: 100%; padding: 15px; border-radius: 15px; border: 2px solid #eee; font-size: 1rem; margin-bottom: 25px; font-weight: 600; color: #444; outline: none; background: #f9f9f9; }

        button { background-color: #5d70f9; color: white; border: none; padding: 18px; border-radius: 20px; font-size: 1.1rem; font-weight: 700; cursor: pointer; transition: 0.3s; width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px; }
        button:hover { transform: translateY(-3px); background-color: #4461f2; box-shadow: 0 10px 20px rgba(93, 112, 249, 0.3); }

        .lista-conquistas { width: 90%; max-width: 500px; margin-top: 50px; }
        .conquista-card { background: white; padding: 20px; border-radius: 25px; margin-bottom: 15px; display: flex; align-items: center; gap: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); animation: fadeIn 0.5s ease; border-left: 8px solid #f1c40f; }
        .conquista-card i { font-size: 1.8rem; width: 40px; text-align: center; }
        .conquista-info p { font-weight: 700; color: #333; }
        .conquista-info small { color: #aaa; font-weight: 600; text-transform: uppercase; font-size: 0.75rem; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <div class="bg-pattern"></div>
    <header>
        <div class="main-icon"><i class="fas fa-trophy"></i></div>
        <h1>Conquistas de Artes</h1>
    </header>

    <div class="container">
        <select id="select-conquista">
            <option value="Entendeu muito bem a matéria">Entendeu muito bem a matéria</option>
            <option value="Acertou tudo">Acertou tudo</option>
            <option value="Acertou quase tudo">Acertou quase tudo</option>
            <option value="Entendeu a matéria">Entendeu a matéria</option>
            <option value="Ficou para aula de reposição">Ficou para aula de reposição</option>
            <option value="Deve estudar mais">Deve estudar mais</option>
        </select>
        <button id="btn-enviar"><i class="fas fa-paper-plane"></i> Enviar ao aluno</button>
    </div>

    <div class="lista-conquistas" id="lista-conquistas"></div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getDatabase, ref, push, onValue } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

        const firebaseConfig = { /* SEU CONFIG AQUI */ };
        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);
        const conquistasRef = ref(db, 'daniel_lucca/conquistas_artes');

        // Mapeamento: Texto -> Ícone e Cor
        const configConquistas = {
            "Entendeu muito bem a matéria": { icon: "fas fa-star", color: "#f1c40f" },
            "Acertou tudo": { icon: "fas fa-check-double", color: "#2ecc71" },
            "Acertou quase tudo": { icon: "fas fa-check", color: "#f39c12" },
            "Entendeu a matéria": { icon: "fas fa-thumbs-up", color: "#3498db" },
            "Ficou para aula de reposição": { icon: "fas fa-clock", color: "#e74c3c" },
            "Deve estudar mais": { icon: "fas fa-book-open", color: "#9b59b6" }
        };

        document.getElementById('btn-enviar').onclick = () => {
            const texto = document.getElementById('select-conquista').value;
            push(conquistasRef, {
                texto: texto,
                materia: "Artes",
                data: new Date().toLocaleDateString('pt-BR')
            });
        };

        onValue(conquistasRef, (snapshot) => {
            const listaHtml = document.getElementById('lista-conquistas');
            listaHtml.innerHTML = '';
            const data = snapshot.val();
            if (data) {
                Object.values(data).reverse().forEach(c => {
                    const config = configConquistas[c.texto] || { icon: "fas fa-award", color: "#f1c40f" };
                    const card = document.createElement('div');
                    card.className = 'conquista-card';
                    card.style.borderLeftColor = config.color;
                    card.innerHTML = `
                        <i class="${config.icon}" style="color: ${config.color}"></i>
                        <div class="conquista-info">
                            <p>${c.texto}</p>
                            <small>${c.materia} • ${c.data}</small>
                        </div>
                    `;
                    listaHtml.appendChild(card);
                });
            }
        });
    </script>
</body>
</html>
